{
  "name": "imkerportal-ruder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "next dev --turbo",
    "dev:backend": "convex dev",
    "predev": "convex dev --until-success && convex dashboard",
    "build": "next build",
    "check": "eslint . --ext .ts,.tsx,.js,.jsx && tsc --noEmit",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx,json,css,html}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx,json,css,html}\" --cache",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.31.9",
    "@clerk/nextjs": "^6.21.0",
    "@clerk/themes": "^2.2.49",
    "@convex-dev/react-query": "0.0.0-alpha.8",
    "@flags-sdk/posthog": "^0.1.0",
    "@next/eslint-plugin-next": "15.4.0-canary.75",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tanstack/react-query": "^5.80.7",
    "@vercel/toolbar": "^0.1.37",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.24.8",
    "convex-helpers": "^0.1.93",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "flags": "^4.0.1",
    "geist": "^1.4.2",
    "lucide-react": "^0.511.0",
    "motion": "^12.17.3",
    "neverthrow": "^8.2.0",
    "next": "15.4.0-canary.75",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.251.0",
    "posthog-node": "^4.18.0",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-feather": "^2.0.10",
    "react-hook-form": "^7.57.0",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript-eslint": "^8.34.0",
    "zod": "^3.25.63",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^20.19.0",
    "@types/react": "19.1.7",
    "@types/react-dom": "19.1.6",
    "eslint": "^9.28.0",
    "eslint-config-next": "15.4.0-canary.75",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.10",
    "tw-animate-css": "^1.3.4",
